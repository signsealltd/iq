generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DIRECTOR
  ESTIMATOR
  STAFF
  CLIENT
  PRODUCTION
  INSTALLER
  READ_ONLY
}

enum CustomerType {
  RETAIL
  TRADE
  FLEET
  COMMERCIAL
  PUBLIC_SECTOR
  INTERNAL
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED_TO_JOB
}

enum VatTreatment {
  STANDARD
  ZERO
  EXEMPT
  OUT_OF_SCOPE
}

enum CostType {
  MATERIAL
  CONSUMABLE
  OUTSOURCED
  EQUIPMENT
  DELIVERY
  OTHER
}

enum JobWorkflowStatus {
  QUOTE
  APPROVED
  ARTWORK
  AWAITING_APPROVAL
  PRODUCTION
  INSTALLATION
  INVOICE
  COMPLETED
}

enum InvoiceStatus {
  NOT_CREATED
  ESTIMATE_CREATED
  INVOICED
  PART_PAID
  PAID
  VOID
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         Role       @default(ESTIMATOR)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sessions     Session[]
  auditLogs    AuditLog[]
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  managedProgrammes ClientProgramme[] @relation("ProgrammeManager")
  programmeAccess ClientProgrammeContact[]
  portalMessages PortalProjectMessage[]
  portalDocuments PortalDocument[]
  artworkApprovals ArtworkApproval[]
  assignedPortalActions ClientActionRequest[] @relation("AssignedPortalActions")
  createdPortalActions ClientActionRequest[] @relation("CreatedPortalActions")
  sentInvitations ClientInvitation[] @relation("SentInvitations")
  passwordResetTokens PasswordResetToken[]
  twoFactor UserTwoFactor?
  portalNotifications PortalNotification[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id                       String       @id @default(cuid())
  company                  String
  contactName              String?
  email                    String?
  phone                    String?
  billingAddress           String?      @db.Text
  vatNumber                String?
  customerType             CustomerType @default(COMMERCIAL)
  notes                    String?      @db.Text
  customerSpecificDiscount Decimal      @default(0) @db.Decimal(6, 4)
  pricingNotes             String?      @db.Text
  discountLevel            String?
  preferredPricingProfile  String?
  archivedAt               DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  quotes                   Quote[]
  jobs                     Job[]
  portalEnabled            Boolean      @default(false)
  portalUsers              User[]
  programmes               ClientProgramme[]
  clientInvitations        ClientInvitation[]
  portalNotifications      PortalNotification[]
}

model Supplier {
  id              String     @id @default(cuid())
  name            String
  contactName     String?
  email           String?
  phone           String?
  address         String?    @db.Text
  leadTimeDays    Int?
  defaultDiscount Decimal    @default(0) @db.Decimal(6, 4)
  notes           String?    @db.Text
  active          Boolean    @default(true)
  archivedAt      DateTime?
  materials Material[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Material {
  id            String    @id @default(cuid())
  name          String
  sku           String?
  category      String?
  unit          String
  unitCost      Decimal   @db.Decimal(10, 2)
  rollWidthMm   Decimal?  @db.Decimal(10, 2)
  rollLengthM   Decimal?  @db.Decimal(10, 2)
  costPerSqm    Decimal?  @db.Decimal(10, 2)
  defaultMarkup Decimal   @default(0.45) @db.Decimal(6, 4)
  supplierId  String?
  active      Boolean   @default(true)
  archivedAt  DateTime?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model LabourRate {
  id                 String   @id @default(cuid())
  name               String   @unique
  internalCostRate   Decimal  @db.Decimal(10, 2)
  customerChargeRate Decimal  @db.Decimal(10, 2)
  minimumCharge      Decimal  @default(0) @db.Decimal(10, 2)
  chargeIncrementMinutes Int   @default(15)
  active             Boolean  @default(true)
  archivedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PricingRule {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  value       Decimal  @db.Decimal(10, 4)
  unit        String
  description String?  @db.Text
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

model PricingMatrixEntry {
  id                  String   @id @default(cuid())
  jobCategory         String
  jobSubtype          String
  unit                String
  minimumPrice        Decimal  @db.Decimal(10, 2)
  targetPrice         Decimal  @db.Decimal(10, 2)
  premiumPrice        Decimal  @db.Decimal(10, 2)
  typicalMaterialCost Decimal  @db.Decimal(10, 2)
  typicalLabourHours  Decimal  @db.Decimal(8, 2)
  defaultDesignHours Decimal   @default(0) @db.Decimal(8, 2)
  defaultProductionHours Decimal @default(0) @db.Decimal(8, 2)
  defaultInstallationHours Decimal @default(0) @db.Decimal(8, 2)
  defaultTravelHours Decimal @default(0) @db.Decimal(8, 2)
  wastePercentage Decimal @default(0.08) @db.Decimal(6, 4)
  minimumMargin       Decimal  @db.Decimal(6, 4)
  targetMargin        Decimal  @db.Decimal(6, 4)
  notes               String?  @db.Text
  active              Boolean  @default(true)
  archivedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Quote {
  id                      String        @id @default(cuid())
  quoteNumber             String        @unique
  status                  QuoteStatus   @default(DRAFT)
  customerId              String
  customer                Customer      @relation(fields: [customerId], references: [id])
  jobTitle                String
  jobCategory             String
  jobSubtype              String?
  description             String        @db.Text
  quantity                Int           @default(1)
  supplyOnly              Boolean       @default(false)
  installed               Boolean       @default(true)
  vehicleType             String?
  vehicleSize             String?
  coverageType            String?
  location                String?
  requiredDate            DateTime?
  urgency                 String?
  scope                   String?       @db.Text
  exclusions              String?       @db.Text
  terms                   String?       @db.Text
  internalNotes           String?       @db.Text
  customerNotes           String?       @db.Text
  calculatedMinimumPrice  Decimal       @db.Decimal(10, 2)
  calculatedRecommendedPrice Decimal    @db.Decimal(10, 2)
  calculatedPremiumPrice  Decimal       @db.Decimal(10, 2)
  finalPrice              Decimal       @db.Decimal(10, 2)
  vat                     Decimal       @db.Decimal(10, 2)
  total                   Decimal       @db.Decimal(10, 2)
  grossProfit             Decimal       @db.Decimal(10, 2)
  grossMargin             Decimal       @db.Decimal(6, 4)
  effectiveHourlyReturn   Decimal       @db.Decimal(10, 2)
  overrideReason          String?
  pricingSnapshot         Json
  expiryDate              DateTime?
  createdAt               DateTime      @default(now())
  sentAt                  DateTime?
  acceptedAt              DateTime?
  rejectedAt              DateTime?
  rejectionReason         String?
  versions                QuoteVersion[]
  costs                   QuoteCost[]
  aiRecommendations       AIRecommendation[]
  job                     Job?
}

model QuoteVersion {
  id        String   @id @default(cuid())
  quoteId   String
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, version])
}

model QuoteCost {
  id            String       @id @default(cuid())
  quoteId       String
  costType      CostType
  description   String
  supplierName  String?
  quantity      Decimal      @db.Decimal(10, 2)
  unitCost      Decimal      @db.Decimal(10, 2)
  markup        Decimal      @db.Decimal(6, 4)
  totalCost     Decimal      @db.Decimal(10, 2)
  vatTreatment  VatTreatment @default(STANDARD)
  internalNotes String?      @db.Text
  quote         Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Job {
  id                   String    @id @default(cuid())
  quoteId              String?   @unique
  customerId           String
  quotedPrice          Decimal   @db.Decimal(10, 2)
  estimatedCosts       Decimal   @db.Decimal(10, 2)
  actualCosts          Decimal?  @db.Decimal(10, 2)
  estimatedHours       Decimal   @db.Decimal(8, 2)
  actualHours          Decimal?  @db.Decimal(8, 2)
  materialsUsed        String?   @db.Text
  installationDate     DateTime?
  completionDate       DateTime?
  finalMargin          Decimal?  @db.Decimal(6, 4)
  varianceFromEstimate Decimal?  @db.Decimal(10, 2)
  notes                String?   @db.Text
  workflowStatus       JobWorkflowStatus @default(QUOTE)
  invoiceStatus        InvoiceStatus @default(NOT_CREATED)
  quickBooksEstimateId String?
  quickBooksInvoiceId  String?
  archivedAt           DateTime?
  quote                Quote?    @relation(fields: [quoteId], references: [id])
  customer             Customer  @relation(fields: [customerId], references: [id])
  costs                JobCost[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model JobCost {
  id          String   @id @default(cuid())
  jobId       String
  description String
  costType    CostType
  quantity    Decimal  @db.Decimal(10, 2)
  unitCost    Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(10, 2)
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model AIRecommendation {
  id             String   @id @default(cuid())
  quoteId        String
  modelUsed      String
  promptVersion  String
  response       Json
  priceBeforeAI  Decimal  @db.Decimal(10, 2)
  priceAfterAI   Decimal? @db.Decimal(10, 2)
  acceptedById   String?
  acceptedAt     DateTime?
  createdAt      DateTime @default(now())
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  @db.Text
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Attachment {
  id           String   @id @default(cuid())
  filename     String
  contentType  String
  sizeBytes    Int
  storageKey   String
  quoteId      String?
  jobId        String?
  uploadedById String?
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

enum PortalProgrammeStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum PortalProjectStatus {
  INITIAL_ENQUIRY
  SITE_SURVEY
  QUOTATION
  ARTWORK
  CLIENT_APPROVAL
  PRODUCTION
  INSTALLATION_SCHEDULED
  INSTALLED
  COMPLETE
  ON_HOLD
}

enum PortalQuoteStatus {
  NOT_STARTED
  DRAFT
  SENT
  ACCEPTED
  CHANGES_REQUESTED
}

enum PortalArtworkStatus {
  NOT_STARTED
  IN_PROGRESS
  PROOF_SENT
  APPROVED
  AMENDMENTS_REQUESTED
}

enum PortalProductionStatus {
  NOT_STARTED
  READY
  IN_PROGRESS
  COMPLETE
}

enum PortalInstallationStatus {
  NOT_SCHEDULED
  SCHEDULED
  IN_PROGRESS
  INSTALLED
  COMPLETE
}

enum PortalMessageVisibility {
  CLIENT_VISIBLE
  INTERNAL_ONLY
}

enum PortalDocumentType {
  SITE_SURVEY
  PHOTOGRAPHS
  QUOTATION
  ARTWORK_PROOF
  APPROVAL
  PURCHASE_ORDER
  INVOICE
  INSTALLATION_DOCUMENTATION
  COMPLETION_PHOTOGRAPHS
  OTHER
}

enum ArtworkApprovalStatus {
  PENDING
  APPROVED
  AMENDMENTS_REQUESTED
  SUPERSEDED
}

enum ClientActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum ClientInvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum EmailTemplateEvent {
  CLIENT_INVITATION
  CLIENT_VISIBLE_MESSAGE
  NEW_ARTWORK_PROOF
  APPROVAL_REQUESTED
  AMENDMENT_REQUESTED
  DOCUMENT_UPLOADED
  INSTALLATION_DATE_CONFIRMED
  CLIENT_ACTION_REQUEST_ASSIGNED
}

enum PortalNotificationStatus {
  QUEUED
  SENT
  FAILED
  SUPPRESSED
}

model ClientProgramme {
  id                       String                @id @default(cuid())
  customerId               String
  name                     String
  summary                  String?               @db.Text
  status                   PortalProgrammeStatus @default(PLANNING)
  targetCompletionDate     DateTime?
  archivedAt               DateTime?
  internalProjectManagerId String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  customer                 Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  internalProjectManager   User?                 @relation("ProgrammeManager", fields: [internalProjectManagerId], references: [id])
  contacts                 ClientProgrammeContact[]
  projects                 ClientProject[]

  @@index([customerId])
  @@index([status])
}

model ClientProgrammeContact {
  id          String          @id @default(cuid())
  programmeId String
  userId      String
  createdAt   DateTime        @default(now())
  programme   ClientProgramme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([programmeId, userId])
  @@index([userId])
}

model ClientProject {
  id                 String                   @id @default(cuid())
  programmeId        String
  name               String
  status             PortalProjectStatus      @default(INITIAL_ENQUIRY)
  siteAddress        String?                  @db.Text
  siteContactName    String?
  siteContactEmail   String?
  siteContactPhone   String?
  description        String?                  @db.Text
  surveyDate         DateTime?
  targetDate         DateTime?
  quoteStatus        PortalQuoteStatus        @default(NOT_STARTED)
  artworkStatus      PortalArtworkStatus      @default(NOT_STARTED)
  productionStatus   PortalProductionStatus   @default(NOT_STARTED)
  installationStatus PortalInstallationStatus @default(NOT_SCHEDULED)
  notes              String?                  @db.Text
  internalNotes      String?                  @db.Text
  archivedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  programme          ClientProgramme          @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  stages             ProjectStage[]
  sites              ClientSite[]
  messages           PortalProjectMessage[]
  documents          PortalDocument[]
  artworkApprovals   ArtworkApproval[]
  actionRequests     ClientActionRequest[]
  notifications      PortalNotification[]

  @@index([programmeId])
  @@index([status])
}

model ClientSite {
  id               String              @id @default(cuid())
  projectId        String
  name             String
  status           PortalProjectStatus @default(INITIAL_ENQUIRY)
  address          String?             @db.Text
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  notes            String?             @db.Text
  internalNotes    String?             @db.Text
  progress         Int                 @default(0)
  archivedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  project          ClientProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeline         ClientSiteTimeline[]
  messages         PortalProjectMessage[]
  documents        PortalDocument[]
  artworkApprovals ArtworkApproval[]
  actionRequests   ClientActionRequest[]

  @@index([projectId])
  @@index([status])
}

model ClientSiteTimeline {
  id          String     @id @default(cuid())
  siteId      String
  label       String
  description String?    @db.Text
  sortOrder   Int
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  site        ClientSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, sortOrder])
  @@index([siteId])
}

model ProjectStage {
  id          String        @id @default(cuid())
  projectId   String
  label       String
  sortOrder   Int
  enabled     Boolean       @default(true)
  completedAt DateTime?
  renamedFrom String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  project     ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, sortOrder])
  @@index([projectId])
}

model PortalProjectMessage {
  id         String                  @id @default(cuid())
  projectId  String
  siteId     String?
  senderId   String?
  senderName String
  body       String                  @db.Text
  visibility PortalMessageVisibility @default(CLIENT_VISIBLE)
  createdAt  DateTime                @default(now())
  project    ClientProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site       ClientSite?              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sender     User?                   @relation(fields: [senderId], references: [id])

  @@index([projectId, visibility])
  @@index([siteId, visibility])
  @@index([senderId])
}

model PortalDocument {
  id           String                  @id @default(cuid())
  projectId    String
  siteId       String?
  filename     String
  contentType  String
  sizeBytes    Int
  storageKey   String
  type         PortalDocumentType      @default(OTHER)
  visibility   PortalMessageVisibility @default(CLIENT_VISIBLE)
  version      Int                     @default(1)
  description  String?                 @db.Text
  uploadedById String?
  createdAt    DateTime                @default(now())
  project      ClientProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site         ClientSite?              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  uploadedBy   User?                   @relation(fields: [uploadedById], references: [id])
  approvals    ArtworkApproval[]

  @@index([projectId, type])
  @@index([siteId, type])
  @@index([visibility])
}

model ArtworkApproval {
  id              String                @id @default(cuid())
  projectId       String
  siteId          String?
  documentId      String?
  proofVersion    Int                   @default(1)
  status          ArtworkApprovalStatus @default(PENDING)
  approverName    String
  approverUserId  String?
  comments        String?               @db.Text
  checksConfirmed Boolean               @default(false)
  createdAt       DateTime              @default(now())
  project         ClientProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site            ClientSite?           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  document        PortalDocument?       @relation(fields: [documentId], references: [id])
  approver        User?                 @relation(fields: [approverUserId], references: [id])

  @@index([projectId, status])
  @@index([siteId, status])
  @@index([documentId])
}

model ClientActionRequest {
  id             String             @id @default(cuid())
  projectId      String
  siteId         String?
  title          String
  description    String?            @db.Text
  dueDate        DateTime?
  status         ClientActionStatus @default(OPEN)
  assignedUserId String?
  completionDate DateTime?
  archivedAt      DateTime?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  project        ClientProject      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  site           ClientSite?        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  assignedUser   User?              @relation("AssignedPortalActions", fields: [assignedUserId], references: [id])
  createdBy      User?              @relation("CreatedPortalActions", fields: [createdById], references: [id])

  @@index([projectId, status])
  @@index([siteId, status])
  @@index([assignedUserId])
}

model ClientInvitation {
  id          String                 @id @default(cuid())
  customerId  String
  email       String
  name        String?
  tokenHash   String                 @unique
  expiresAt   DateTime
  status      ClientInvitationStatus @default(PENDING)
  invitedById String?
  acceptedAt  DateTime?
  createdAt   DateTime               @default(now())
  customer    Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invitedBy   User?                  @relation("SentInvitations", fields: [invitedById], references: [id])

  @@index([customerId, email])
  @@index([status])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserTwoFactor {
  id              String   @id @default(cuid())
  userId          String   @unique
  enabled         Boolean  @default(false)
  secretEncrypted String?  @db.Text
  recoveryCodes   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String             @id @default(cuid())
  event     EmailTemplateEvent @unique
  subject   String
  body      String             @db.Text
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model PortalNotification {
  id         String                   @id @default(cuid())
  event      EmailTemplateEvent
  status     PortalNotificationStatus @default(QUEUED)
  userId     String?
  customerId String?
  projectId  String?
  payload    Json?
  error      String?                  @db.Text
  archivedAt DateTime?
  createdAt  DateTime                 @default(now())
  sentAt     DateTime?
  user       User?                    @relation(fields: [userId], references: [id])
  customer   Customer?                @relation(fields: [customerId], references: [id])
  project    ClientProject?           @relation(fields: [projectId], references: [id])

  @@index([event, status])
  @@index([customerId])
  @@index([projectId])
}



